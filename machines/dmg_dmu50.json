    },
    {
      "group_a": "tool_group",
      "group_b": "stock",
      "clearance_mm": 0.0,
      "check_type": "during_cut"
    },
    {
      "group_a": "spindle_group",
      "group_b": "stock",
      "clearance_mm": 8.0,
      "check_type": "static"
    }
  ],

  "home_position": [0, 225, 0, 0, 0, 0],
  "tool_change_position": [0, 225, -400, 0, 0, 0],
  "axis_priority": ["Z"],
  "retract_axis": "Z",

  "work_offset_defaults": {
    "G54": [250, 225, 75, 0, 0, 0]
