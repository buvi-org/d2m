    "table_group": ["c_axis", "b_axis", "x_axis", "y_axis"],
    "trunnion_group": ["b_axis", "c_axis"],
    "fixture_group": ["fixture_mount"]
  },

  "collision_pairs": [
    {
      "group_a": "tool_group",
