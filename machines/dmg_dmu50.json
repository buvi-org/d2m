  "kinematic_chain": {
    "tool_chain": ["tool_mount", "spindle", "z_axis", "column", "bed"],
    "workpiece_chain": ["fixture_mount", "c_axis", "b_axis", "x_axis", "y_axis", "bed"]
  }
